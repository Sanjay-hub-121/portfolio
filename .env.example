# ============================================
# REQUIRED: Neon PostgreSQL Connection String
# Get this from neon.tech dashboard
# ============================================
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ============================================
# REQUIRED: NextAuth Configuration
# Generate secret: openssl rand -base64 32
# ============================================
NEXTAUTH_SECRET="generate-a-strong-secret-here"
NEXTAUTH_URL="https://yourdomain.com"
# For local dev:
# NEXTAUTH_URL="http://localhost:3000"

# ============================================
# OPTIONAL: Email (Contact Form Notifications)
# Use Gmail App Password (not your main password)
# Gmail → Security → 2FA → App Passwords
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-16-char-app-password"
CONTACT_EMAIL="your@gmail.com"

# ============================================
# OPTIONAL: Cloudinary (Image Uploads)
# Get from cloudinary.com dashboard
# ============================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
